app:
  hotkey: Control+Space
  hotkey_mode: toggle             # 热键模式：toggle=按一次开始再按一次结束，hold=按住说话松开结束
  remove_trailing_period: true   # 自动删除识别结果末尾的句号（。或 .）
  keep_clipboard: true           # 保留识别结果在剪贴板，便于失败后手动再次粘贴
  theme: system                  # 外观主题：dark / light / system（跟随系统）
  accent_theme: purple           # 重点色系统：purple / green

sounds:
  enabled: true                  # 启用提示音总开关
  start: true                    # 开始录音提示音
  end: true                      # 结束粘贴提示音
  volume: 0.72                   # 提示音音量 0~1

overlay:
  background_color: "#0d0c0c"   # 气泡背景色（十六进制）
  background_opacity: 0.9       # 气泡背景透明度 0~1
  border_color: "#ffffff"       # 边框颜色（十六进制）
  border_width: 0               # 边框宽度 px，0 = 无边框
  border_radius: 16             # 圆角半径 px
  font_family: DengXian         # 字体名称，留空使用系统默认（微软雅黑等）
  font_size: 16                 # 字号 px
  font_weight: 400              # 字重：300 / 400 / 500 / 600 / 700
  text_color: "#34da66"         # 已识别文字颜色
  partial_text_color: "#ffffff" # 识别中文字颜色
  partial_text_opacity: 0.64    # 识别中文字透明度 0~1
  waveform_color: "#29ee63"     # 波形动画颜色
  max_width: 680                # 气泡最大宽度 px

overlay_active_preset: default   # 当前浮层外观方案：default / preset_1 / preset_2 / preset_3
overlay_presets: {}              # 三套自定义浮层外观方案，由设置页保存

connection:
  url: wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
  app_id: ""
  access_token: ""
  secret_key: ""
  resource_id: "volc.seedasr.sauc.duration"

audio:
  format: pcm          # pcm / wav / ogg / mp3
  codec: raw            # raw / opus，ogg 时必须 opus
  rate: 16000           # 采样率，仅支持 16000
  bits: 16              # 采样位深，仅支持 16
  channel: 1            # 1=单声道，2=立体声

request:
  model_name: bigmodel            # 固定 bigmodel
  model_version: "400"
  operation: submit
  sequence: 0
  enable_itn: true                # 文本规范化：数字日期自动格式化
  enable_punc: true               # 自动标点
  enable_ddc: true                # 语义顺滑：去除停顿词、语气词、重复词
  enable_nonstream: true          # 二遍识别：实时返回+非流式重识别提升准确率，仅 bigmodel_async 支持
  show_utterances: true           # 输出分句信息（start_time / end_time / definite）
  result_type: full               # full=全量返回，single=增量返回
  vad_segment_duration: 3000      # 当静音时间超过该值时，会将文本分为两个句子。与 end_window_size 不可同时使用
  # end_window_size: 1000         # 静音判停阈值(ms)，最小200，超时输出 definite 分句
  # force_to_speech_time: 1000    # 音频时长阈值(ms)，配合 end_window_size，低于此值不判停
  enable_speaker_info: false      # 说话人聚类分离，需配合 ssd_version=200
  ssd_version: ""                 # 设 "200" 启用大模型 SSD
  output_zh_variant: ""           # 繁体输出：traditional / tw / hk，留空不转换
  show_speech_rate: false         # 分句携带语速 (token/s)，启用后自动开启 VAD 分句
  show_volume: false              # 分句携带音量 (dB)，启用后自动开启 VAD 分句
  enable_lid: false               # 语种检测：中英/上海话/闽南语/川/陕/粤语
  enable_accelerate_text: true    # 首字返回加速，会降低首字准确率
  accelerate_score: 10            # 首字加速率 [0-20]，配合 enable_accelerate_text，越大越快
  sensitive_words_filter: ""      # 敏感词过滤，JSON 字符串格式
  corpus:
    boosting_table_id: ""         # 热词表 ID（自学习平台）
    boosting_table_name: ""       # 热词表名称
    correct_table_id: ""          # 替换词表 ID（自学习平台）
    correct_table_name: ""        # 替换词表名称
    context_hotwords: Claude Code, Claude, mermaid, AGENTS.md, skills, codex, OpenAI, ChatGPT, GLM, cronjob, hermes, openclaw, obsidian, schema, skill, agent  # 逗号分隔的热词列表

llm:
  enabled: false              # 启用 LLM 文本润色
  provider: deepseek          # deepseek / openai / anthropic / gemini / openrouter / siliconflow / ollama / openai_compatible
  deepseek:
    url: ""                   # 内置默认地址，可留空
    api_key: ""
    model: deepseek-v4-flash
  openai:
    url: ""                   # 内置默认地址，可留空
    api_key: ""
    model: gpt-4o-mini
  anthropic:
    url: ""                   # Anthropic 原生协议可留空
    api_key: ""
    model: claude-3-5-haiku-latest
  gemini:
    url: ""                   # 内置默认地址，可留空
    api_key: ""
    model: gemini-2.5-flash-lite
  openrouter:
    url: https://openrouter.ai/api/v1
    api_key: ""
    model: openai/gpt-4o-mini
  siliconflow:
    url: https://api.siliconflow.cn/v1
    api_key: ""
    model: deepseek-ai/DeepSeek-V3
  ollama:
    url: http://localhost:11434/api
    api_key: ""
    model: llama3.1
  openai_compatible:
    url: ""
    api_key: ""
    model: ""

analysis_package:
  output_dir: ""               # 分析包长期存放目录；首次生成分析包时可在界面中选择
